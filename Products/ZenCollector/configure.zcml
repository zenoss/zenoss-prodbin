<?xml version="1.0"?>
<configure xmlns="http://namespaces.zope.org/zope">

   <utility
      factory=".tasks.SingleWorkerTaskFactory"
      provides=".interfaces.IWorkerTaskFactory"
      />

   <utility
      factory=".tasks.NullWorkerExecutor"
      provides=".interfaces.IWorkerExecutor"
      />

   <utility
      factory=".statistics.StatisticsServiceFactory"
      name="statistics-service"
      />

</configure>
